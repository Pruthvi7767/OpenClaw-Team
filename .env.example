# Copy this to .env and fill in your values
# NEVER commit .env to GitHub

# System
NODE_ENV=production
PORT=3000

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=your_anon_key_here

# Email Service (Choose one)
EMAIL_SERVICE=gmail
GMAIL_USER=outreach@yourdomain.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# OR use Resend
# EMAIL_SERVICE=resend
# RESEND_API_KEY=re_xxxxx

# Google OAuth (for Gmail API)
GMAIL_CLIENT_ID=xxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=xxxxx
GMAIL_REFRESH_TOKEN=xxxxx

# APIs - Account 1
SERPER_API_KEY=xxxxx
APIFY_API_KEY_1=xxxxx

# APIs - Account 2
APIFY_API_KEY_2=xxxxx

# Fallback APIs
SCRAPE_DO_API_KEY=xxxxx
WEBSCRAPING_AI_KEY=xxxxx

# LLMs
OPENROUTER_API_KEY=xxxxx
NVIDIA_API_KEY=xxxxx

# Telegram
TELEGRAM_BOT_TOKEN=xxxxx
TELEGRAM_USER_ID=xxxxx

# Payment (Optional)
RAZORPAY_KEY_ID=xxxxx
RAZORPAY_KEY_SECRET=xxxxx
UPI_ID=yourname@paytm
UPI_START_AMOUNT=301

# System Control
AUTO_START=true
DAILY_EMAIL_LIMIT=50
DAILY_LEAD_LIMIT=10
